# Copy this file to .env and fill in real values. .env is gitignored;
# sample.env is the template that gets committed.

# Django's secret key. Generate one, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# True for local development, False (or omit) in production.
DEBUG=True

# Comma-separated list of email domains allowed to sign up / be invited.
# Empty means no domain is allowed.
USER_EMAIL_DOMAINS=example.com
